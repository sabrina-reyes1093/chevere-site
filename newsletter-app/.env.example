# Public service URLs
NEXT_PUBLIC_SITE_URL=https://www.itschevere.com
NEXT_PUBLIC_NEWSLETTER_URL=https://newsletter.itschevere.com

# Supabase project
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Admin access: create this user in Supabase Auth first
ADMIN_EMAIL=sabrina@example.com
ADMIN_USERNAME=sabrinareyes1

# Resend and verified sender identity
RESEND_API_KEY=
NEWSLETTER_FROM=The Edit, Delivered <newsletter@itschevere.com>
NEWSLETTER_REPLY_TO=sabrina@itschevere.com
NEWSLETTER_POSTAL_ADDRESS=[INSERT MAILING ADDRESS OR PO BOX]
NEWSLETTER_SEND_TIME=08:30
RESEND_WEBHOOK_SECRET=

# Security (generate long, random values)
TOKEN_SECRET=
CRON_SECRET=

# Safety switch: leave false until the complete production checklist passes
NEWSLETTER_CRON_ENABLED=false

# Publishing blog posts from a hosted portal. Without these, publishing writes
# files directly and only works when the app runs from inside the site repo.
# The token needs "Contents: read and write" on the site repository only.
GITHUB_TOKEN=
GITHUB_REPO=sabrina-reyes1093/chevere
GITHUB_BRANCH=main
